{
  "$schema": "https://typedoc.org/schema.json",
  "entryPointStrategy": "packages",
  "entryPoints": [
    "packages/admin",
    "packages/ai",
    "packages/auth",
    "packages/billing",
    "packages/bridge",
    "packages/cache",
    "packages/cli",
    "packages/core",
    "packages/db",
    "packages/edge",
    "packages/events",
    "packages/faker",
    "packages/flags",
    "packages/foundation",
    "packages/graphql",
    "packages/helpers",
    "packages/http",
    "packages/http-client",
    "packages/i18n",
    "packages/log",
    "packages/mail",
    "packages/mcp",
    "packages/media",
    "packages/notifications",
    "packages/orm",
    "packages/otel",
    "packages/padlock",
    "packages/queue",
    "packages/realtime",
    "packages/resilience",
    "packages/scheduler",
    "packages/session",
    "packages/sociallock",
    "packages/storage",
    "packages/tenancy",
    "packages/testing",
    "packages/ui",
    "packages/validation",
    "packages/wasm"
  ],
  "out": "docs/api",
  "name": "Carpenter Framework",
  "readme": "README.md",
  "includeVersion": true,
  "excludePrivate": true,
  "excludeInternal": true,
  "excludeExternals": true,
  "categorizeByGroup": true,
  "searchInComments": true,
  "navigation": {
    "includeCategories": true,
    "includeGroups": true
  },
  "sort": ["alphabetical"],
  "kindSortOrder": [
    "Module",
    "Namespace",
    "Enum",
    "Class",
    "Interface",
    "TypeAlias",
    "Function",
    "Variable"
  ],
  "visibilityFilters": {
    "protected": true,
    "@alpha": false,
    "@beta": true
  },
  "plugin": [],
  "tsconfig": "tsconfig.base.json"
}
