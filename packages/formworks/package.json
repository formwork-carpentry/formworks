    "./media":        { "import": "./dist/media/index.js",        "types": "./dist/media/index.d.ts" },
    "./testing":      { "import": "./dist/testing/index.js",      "types": "./dist/testing/index.d.ts" },
    "./faker":        { "import": "./dist/faker/index.js",        "types": "./dist/faker/index.d.ts" },
    "./encrypt":      { "import": "./dist/encrypt/index.js",      "types": "./dist/encrypt/index.d.ts" },
    "./pipeline":     { "import": "./dist/pipeline/index.js",     "types": "./dist/pipeline/index.d.ts" },
    "./number":       { "import": "./dist/number/index.js",       "types": "./dist/number/index.d.ts" },
    "./crypto":       { "import": "./dist/crypto/index.js",       "types": "./dist/crypto/index.d.ts" }
