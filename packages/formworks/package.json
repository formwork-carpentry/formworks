{
  "name": "@carpentry/formworks",
  "version": "1.0.0",
  "description": "Carpenter Framework — component library",
  "type": "module",
  "exports": {
    ".":              { "import": "./dist/index.js",              "types": "./dist/index.d.ts" },
    "./core":         { "import": "./dist/core/index.js",         "types": "./dist/core/index.d.ts" },
    "./http":         { "import": "./dist/http/index.js",         "types": "./dist/http/index.d.ts" },
    "./foundation":   { "import": "./dist/foundation/index.js",   "types": "./dist/foundation/index.d.ts" },
    "./auth":         { "import": "./dist/auth/index.js",         "types": "./dist/auth/index.d.ts" },
    "./orm":          { "import": "./dist/orm/index.js",          "types": "./dist/orm/index.d.ts" },
    "./validation":   { "import": "./dist/validation/index.js",   "types": "./dist/validation/index.d.ts" },
    "./events":       { "import": "./dist/events/index.js",       "types": "./dist/events/index.d.ts" },
    "./session":      { "import": "./dist/session/index.js",      "types": "./dist/session/index.d.ts" },
    "./log":          { "import": "./dist/log/index.js",          "types": "./dist/log/index.d.ts" },
