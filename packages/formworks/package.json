    "@carpentry/i18n":          "workspace:*",
    "@carpentry/ui":            "workspace:*",
    "@carpentry/helpers":       "workspace:*",
    "@carpentry/http-client":   "workspace:*",
    "@carpentry/media":         "workspace:*",
    "@carpentry/encrypt":       "workspace:*",
    "@carpentry/pipeline":      "workspace:*",
    "@carpentry/number":        "workspace:*",
    "@carpentry/crypto":        "workspace:*"
  },
  "devDependencies": {
    "@carpentry/testing":       "workspace:*",
    "@carpentry/faker":         "workspace:*",
    "tsup":                     "^8.0.0",
    "typescript":               "^5.4.0"
  }
